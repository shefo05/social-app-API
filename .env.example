# Server
PORT = 3000

# MongoDB (use a MongoDB Atlas connection string in production)
DB_URL = mongodb://127.0.0.1:27017/social-app

# Redis (Upstash or any hosted Redis works on free tiers)
REDIS_URL = redis://default:password@host:port

# Resend (used for sending OTP/verification emails via HTTP API - no SMTP)
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY = re_your_api_key_here
# Sandbox sender works without a verified domain, but can only send to your
# own Resend account email until you verify a custom domain.
RESEND_FROM_EMAIL = onboarding@resend.dev

# JWT secrets — generate strong random values, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET = replace-with-a-random-64-char-hex-string
JWT_REFRESH_SECRET = replace-with-a-different-random-64-char-hex-string

# AWS S3 (file uploads)
S3_REGION = region-ex
S3_BUCKET_NAME = bucket-name-ex
S3_ACCESS_KEY_ID = id-ex
S3_SECRET_ACCESS_KEY = secret-key-ex
