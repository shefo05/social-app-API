# Server
PORT = 3000

# MongoDB (use a MongoDB Atlas connection string in production)
DB_URL = mongodb://127.0.0.1:27017/social-app

# Redis (Upstash or any hosted Redis works on free tiers)
REDIS_URL = redis://default:password@host:port

# SendGrid (used for sending OTP/verification emails via HTTP API - no SMTP)
# Get an API key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY = SG.your_api_key_here
# Must exactly match a verified Single Sender (or domain sender) in SendGrid's
# Sender Authentication settings - sends fail if this doesn't match exactly.
SENDGRID_FROM_EMAIL = your-verified-sender@example.com

# JWT secrets — generate strong random values, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET = replace-with-a-random-64-char-hex-string
JWT_REFRESH_SECRET = replace-with-a-different-random-64-char-hex-string

# Cloudinary (file uploads - post attachments, profile avatars)
# Get these 3 values from the Cloudinary dashboard home page
CLOUDINARY_CLOUD_NAME = your-cloud-name
CLOUDINARY_API_KEY = your-api-key
CLOUDINARY_API_SECRET = your-api-secret
