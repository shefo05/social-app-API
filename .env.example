# Server
PORT = 3000

# MongoDB (use a MongoDB Atlas connection string in production)
DB_URL = mongodb://127.0.0.1:27017/social-app

# Redis (Upstash or any hosted Redis works on free tiers)
REDIS_URL = redis://default:password@host:port

# SendGrid (used for sending OTP/verification emails via HTTP API - no SMTP)
# Get an API key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY = SG.your_api_key_here
# Must exactly match a verified Single Sender (or domain sender) in SendGrid's
# Sender Authentication settings - sends fail if this doesn't match exactly.
SENDGRID_FROM_EMAIL = your-verified-sender@example.com

# JWT secrets — generate strong random values, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET = replace-with-a-random-64-char-hex-string
JWT_REFRESH_SECRET = replace-with-a-different-random-64-char-hex-string

# Cloudinary (file uploads - post attachments, profile avatars)
# Get these 3 values from the Cloudinary dashboard home page
CLOUDINARY_CLOUD_NAME = your-cloud-name
CLOUDINARY_API_KEY = your-api-key
CLOUDINARY_API_SECRET = your-api-secret

# Shared fallback avatar URL for users without a profilePic - upload
# public/avatarr.png (or your own default) to Cloudinary once and paste
# the resulting secure_url here.
DEFAULT_AVATAR_URL = https://res.cloudinary.com/your-cloud-name/image/upload/.../default-avatar.webp

# Google OAuth client id - create an OAuth 2.0 Client ID (Web application)
# at https://console.cloud.google.com/apis/credentials. No client secret
# needed - the frontend gets an ID token directly via Google Identity
# Services, and the backend only verifies its signature/audience.
GOOGLE_CLIENT_ID = your-client-id.apps.googleusercontent.com

# Comma-separated browser origins allowed to call this API (REST CORS +
# Socket.IO handshake CORS) - e.g. https://your-app.vercel.app,http://localhost:3000
ALLOWED_ORIGINS = http://localhost:3000
