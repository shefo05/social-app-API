# Server
PORT = 3000

# MongoDB (use a MongoDB Atlas connection string in production)
DB_URL = mongodb://127.0.0.1:27017/social-app

# Gmail SMTP (used for sending OTP/verification emails)
SEND_MAIL_USER = your-email@gmail.com
SEND_MAIL_PASS = your-gmail-app-password

# Redis (Upstash or any hosted Redis works on free tiers)
REDIS_URL = redis://default:password@host:port

# JWT secrets — generate strong random values, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET = replace-with-a-random-64-char-hex-string
JWT_REFRESH_SECRET = replace-with-a-different-random-64-char-hex-string

# AWS S3 (file uploads)
S3_REGION = region-ex
S3_BUCKET_NAME = bucket-name-ex
S3_ACCESS_KEY_ID = id-ex
S3_SECRET_ACCESS_KEY = secret-key-ex
