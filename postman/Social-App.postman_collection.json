{
  "info": {
    "_postman_id": "7d7e1d75-4b7f-4fcc-a325-fa325ab154e5",
    "name": "Social App API",
    "description": "REST + GraphQL API for the social_app Express backend, deployed at {{base_url}} (Render free tier).\n\nQuick start:\n1. Run Auth > 1. Signup\n2. Check the inbox for the signup email address for the OTP, then run Auth > 2. Verify Account (OTP) with the real code\n3. Run Auth > 3. Login - this auto-saves the access token into {{token}}\n4. All other requests marked 'Requires auth' will now work automatically via the collection's {{token}} variable\n\nNote: free-tier cold start - the first request after 15 minutes of inactivity can take 30-50s to respond while Render spins the instance back up.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "1. Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "url": {
              "raw": "{{base_url}}/auth/signup",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "signup"
              ]
            },
            "description": "Creates a pending signup and emails an OTP to the given address (sent from SEND_MAIL_USER via Gmail SMTP). The user is NOT written to the DB until /auth/verify-account succeeds. gender is optional: 0 = male, 1 = female. phoneNumber must match Egyptian format (01/+201/00201 + [0,1,2,5] + 8 digits). password needs 1 uppercase, 1 lowercase, 1 digit, 1 special char, 8+ length.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo.user@example.com\",\n  \"password\": \"Demo@1234\",\n  \"userName\": \"demoUser\",\n  \"phoneNumber\": \"01012345678\",\n  \"gender\": 0\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "2. Verify Account (OTP)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "url": {
              "raw": "{{base_url}}/auth/verify-account",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "verify-account"
              ]
            },
            "description": "Check the inbox for demo.user@example.com for the real 6-digit OTP emailed by /auth/signup, then replace the otp value here before sending. On success the user is actually created in MongoDB.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo.user@example.com\",\n  \"otp\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Send OTP (resend / forgot password)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "url": {
              "raw": "{{base_url}}/auth/send-otp",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "send-otp"
              ]
            },
            "description": "Re-sends an OTP for an existing pending signup, or (while authenticated) generates the OTP needed for /auth/reset-password. Fails with 400 if a still-valid OTP already exists (3 min TTL).",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo.user@example.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "3. Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "description": "Returns { accessToken, refreshToken } in data. FCM (push token) is an optional extra field. Running this request automatically saves accessToken into the {{token}} collection variable via its Tests script - run this before any authenticated request below.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo.user@example.com\",\n  \"password\": \"Demo@1234\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (pm.response.code === 200 && jsonData.data && jsonData.data.accessToken) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.data.accessToken);",
                  "    console.log(\"Saved accessToken to {{token}}\");",
                  "}",
                  "pm.test(\"Login returned 200 with an accessToken\", function () {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(jsonData.data.accessToken).to.be.a(\"string\");",
                  "});"
                ]
              }
            }
          ]
        },
